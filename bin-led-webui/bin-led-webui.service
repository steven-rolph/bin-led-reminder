[Unit]
Description=Bin LED Web UI
After=network.target

[Service]
Type=simple
User=pizero2
WorkingDirectory=/home/pizero2/blinkt-projects/bin-led-webui
ExecStart=/home/pizero2/blinkt-projects/blinkt-env/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure

[Install]
WantedBy=multi-user.target
